<?xml version="1.0" encoding="UTF-8"?>
<windows>

  <!-- Player Inventory -->
  <setattribute xpath="/windows/window[@name='windowBackpack']/rect[@name='header']/rect[@controller='ContainerStandardControls']" name="pos">175,0 </setattribute>

  <append xpath="/windows/window[@name='windowBackpack']/rect[@name='header']/rect[@controller='ContainerStandardControls']">

    <rect name="beyondsmart_bp_player_backpack_only" visible="{bs_is_player_backpack_only}">
      <button depth="3" name="btnBeyondSmartPlayerInventoryPullLoadout" sprite="ui_symbol_beyond_smart_loot_pull_loadout" tooltip_key="btnBeyondSmartPlayerInventoryPullLoadout_ToolTip" pos="200, -22" style="icon32px, press, hover" pivot="center" sound="[paging_click]" />
      <button depth="3" name="btnBeyondSmartPlayerInventoryPush" sprite="ui_symbol_beyond_smart_loot_push" tooltip_key="btnBeyondSmartPlayerInventoryPush_ToolTip" pos="240, -22" style="icon32px, press, hover" pivot="center" sound="[paging_click]" />
    </rect>

    <rect name="beyondsmart_bp_player_looting" visible="{lootingorvehiclestorage}">
      <button depth="3" name="btnBeyondSmartPlayerLootingPullLoadout" sprite="ui_symbol_beyond_smart_loot_pull_loadout" tooltip_key="btnBeyondSmartPlayerInventoryPullLoadout_ToolTip" pos="200, -22" style="icon32px, press, hover" pivot="center" sound="[paging_click]" />
      <button depth="3" name="btnBeyondSmartPlayerLootingPush" sprite="ui_symbol_beyond_smart_loot_push" tooltip_key="btnBeyondSmartPlayerInventoryPush_ToolTip" pos="240, -22" style="icon32px, press, hover" pivot="center" sound="[paging_click]" />
    </rect>

  </append>

  <!-- Player Inventory for AGF V3 Larger Backpacks 60-72-84-119 -->
  <conditional>
    <if cond="mod_loaded('AGF-BackpackPlus-060Slots') or mod_loaded('AGF-BackpackPlus-072Slots') or mod_loaded('AGF-BackpackPlus-084Slots') or mod_loaded('AGF-BackpackPlus-119Slots')">
      <setattribute xpath="/windows/window[@name='windowBackpackAGF']/rect[@name='header']/rect[@controller='ContainerStandardControls']" name="pos">175,0 </setattribute>

      <append xpath="/windows/window[@name='windowBackpackAGF']/rect[@name='header']/rect[@controller='ContainerStandardControls']">

        <rect name="beyondsmart_bp_player_backpack_only" visible="{bs_is_player_backpack_only}">
          <button depth="3" name="btnBeyondSmartPlayerInventoryPullLoadout" sprite="ui_symbol_beyond_smart_loot_pull_loadout" tooltip_key="btnBeyondSmartPlayerInventoryPullLoadout_ToolTip" pos="200, -22" style="icon32px, press, hover" pivot="center" sound="[paging_click]" />
          <button depth="3" name="btnBeyondSmartPlayerInventoryPush" sprite="ui_symbol_beyond_smart_loot_push" tooltip_key="btnBeyondSmartPlayerInventoryPush_ToolTip" pos="240, -22" style="icon32px, press, hover" pivot="center" sound="[paging_click]" />
        </rect>

        <rect name="beyondsmart_bp_player_looting" visible="{lootingorvehiclestorage}">
          <button depth="3" name="btnBeyondSmartPlayerLootingPullLoadout" sprite="ui_symbol_beyond_smart_loot_pull_loadout" tooltip_key="btnBeyondSmartPlayerInventoryPullLoadout_ToolTip" pos="200, -22" style="icon32px, press, hover" pivot="center" sound="[paging_click]" />
          <button depth="3" name="btnBeyondSmartPlayerLootingPush" sprite="ui_symbol_beyond_smart_loot_push" tooltip_key="btnBeyondSmartPlayerInventoryPush_ToolTip" pos="240, -22" style="icon32px, press, hover" pivot="center" sound="[paging_click]" />
        </rect>

      </append>
    </if>
  </conditional>

  <!-- Dew Collectors / Apiaries -->
  <append xpath="/windows/window[@name='windowDewCollector']/rect[@name='header']/rect">
    <rect name="beyondsmart_bp_collector" visible="true">
      <button depth="3" name="btnBeyondSmartCollectorPush" sprite="ui_symbol_beyond_smart_loot_push" tooltip_key="btnBeyondSmartCollectorPush_ToolTip" pos="280, -22" style="icon32px, press, hover" pivot="center" sound="[paging_click]" />
    </rect>
  </append>

  <!-- Loot Containers -->
  <append xpath="/windows/window[@name='windowLooting']/rect[@name='header']/rect">
    <rect name="beyondsmart_bp_loot" visible="{bs_is_player_storage_open}">
      <button depth="3" name="btnBeyondSmartStoragePush" sprite="ui_symbol_beyond_smart_loot_push" tooltip_key="btnBeyondSmartLootWindowPush_ToolTip" pos="110, -22" style="icon32px, press, hover" pivot="center" sound="[paging_click]" />
    </rect>
  </append>

  <!-- Vehicles + Drones -->
  <append xpath="/windows/window[@name='windowBagStorage']/rect[@name='header']/rect">
    <rect name="beyondsmart_bp_vehicle" visible="true" anchor_left="queue,1,-240" anchor_right="queue,1,0">
      <button depth="3" name="btnBeyondSmartDronePullLoadout" visible="{bs_is_drone_window_open}" sprite="ui_symbol_beyond_smart_loot_pull_loadout" tooltip_key="btnBeyondSmartDronePullLoadout_ToolTip" pos="0, -22" style="icon32px, press, hover" pivot="center" sound="[paging_click]" />
      <button depth="3" name="btnBeyondSmartVehiclePullLoadout" visible="{% !bs_is_drone_window_open}" sprite="ui_symbol_beyond_smart_loot_pull_loadout" tooltip_key="btnBeyondSmartVehiclePullLoadout_ToolTip" pos="0, -22" style="icon32px, press, hover" pivot="center" sound="[paging_click]" />
      <button depth="3" name="btnBeyondSmartVehiclePush" sprite="ui_symbol_beyond_smart_loot_push" tooltip_key="btnBeyondSmartVehiclePush_ToolTip" pos="40, -22" style="icon32px, press, hover" pivot="center" sound="[paging_click]" />
    </rect>
  </append>

  <!-- Workstation Output -->
  <append xpath="/windows/window[@name='windowOutput']/rect[@style='header.panel']/rect">
    <rect name="beyondsmart_bp_workstation_output" visible="true">
      <button depth="3" name="btnBeyondSmartWorkstationOutputPush" sprite="ui_symbol_beyond_smart_loot_push" tooltip_key="btnBeyondSmartWorkstationOutputPush_ToolTip" pos="168, -22" style="icon32px, press, hover" pivot="center" sound="[paging_click]" />
    </rect>
  </append>

</windows>